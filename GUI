-- TOGGLE SWITCH FACTORY
local function makeToggle(parent, onChange)
    local state = false
    local Track = Instance.new("Frame")
    Track.Size             = UDim2.fromOffset(46, 25)
    Track.BackgroundColor3 = C.trackOFF
    Track.BorderSizePixel  = 0
    Track.Parent           = parent
    rnd(Track, 13)
    local TStroke = brd(Track, C.border, 1)

    local Thumb = Instance.new("Frame")
    Thumb.Size             = UDim2.fromOffset(19, 19)
    Thumb.Position         = UDim2.new(0, 3, .5, -9.5)
    Thumb.BackgroundColor3 = C.thumbOFF
    Thumb.BorderSizePixel  = 0
    Thumb.ZIndex           = 2
    Thumb.Parent           = Track
    rnd(Thumb, 10)

    local HitBox = Instance.new("TextButton")
    HitBox.Size                   = UDim2.new(1,0,1,0)
    HitBox.BackgroundTransparency = 1
    HitBox.Text                   = ""
    HitBox.ZIndex                 = 3
    HitBox.Parent                 = Track

    HitBox.MouseButton1Click:Connect(function()
        state = not state
        if state then
            tw(Track, .2,  {BackgroundColor3 = C.trackON})
            tw(Thumb, .22, {Position=UDim2.new(0,24,.5,-9.5), BackgroundColor3=C.thumbON}, Enum.EasingStyle.Back)
            TStroke.Color = C.green
        else
            tw(Track, .2,  {BackgroundColor3 = C.trackOFF})
            tw(Thumb, .22, {Position=UDim2.new(0, 3,.5,-9.5), BackgroundColor3=C.thumbOFF}, Enum.EasingStyle.Back)
            TStroke.Color = C.border
        end
        if onChange then onChange(state) end
    end)
end

