-- BUTTON 1 — FREEZE TRADE
makeCard(68, "❄", "Freeze Trade", "Khoá giao dịch", C.blue, true, function(on)
    if on then
        showToast("❄", "Freeze Trade  BẬT", "Giao dịch đã bị khoá!", C.blue)
    else
        showToast("❄", "Freeze Trade  TẮT", "Giao dịch đã được mở lại.", C.sub)
    end
    pcall(function()
        local pg = LP:FindFirstChild("PlayerGui")
        if not pg then return end
        for _, g in ipairs(pg:GetDescendants()) do
            if g:IsA("TextButton") then
                local n = g.Name:lower()
                if n:find("confirm") or n:find("accept") or n:find("trade") then
                    g.Active = not on
                end
            end
        end
    end)
end)

-- BUTTON 2 — FORCE ACCEPT
local forceActive = false
makeCard(144, "✓", "Force to Accept", "Tự động chấp nhận trade", C.green, true, function(on)
    forceActive = on
    if on then
        showToast("✓", "Force Accept  BẬT", "Đang tự động chấp nhận trade.", C.green)
        task.spawn(function()
            while forceActive do
                task.wait(0.45)
                pcall(function()
                    local pg = LP:FindFirstChild("PlayerGui")
                    if not pg then return end
                    for _, g in ipairs(pg:GetDescendants()) do
                        if g:IsA("TextButton") and g.Active then
                            local n = g.Name:lower()
                            if n:find("accept") or n:find("confirm") or n:find("ok") then
                                g:activate()
                            end
                        end
                    end
                end)
            end
        end)
    else
        showToast("✓", "Force Accept  TẮT", "Đã dừng tự động chấp nhận.", C.sub)
    end
end)

