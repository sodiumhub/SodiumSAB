-- TOAST SYSTEM
local toastQueue = {}
local toastBusy  = false

local function showToast(icon, title, msg, col)
    table.insert(toastQueue, {icon=icon, title=title, msg=msg, col=col})
    if toastBusy then return end
    toastBusy = true
    task.spawn(function()
        while #toastQueue > 0 do
            local item = table.remove(toastQueue, 1)
            local T = Instance.new("Frame")
            T.Size             = UDim2.fromOffset(270, 56)
            T.Position         = UDim2.new(1, 10, 0, 16)
            T.BackgroundColor3 = Color3.fromRGB(13, 13, 22)
            T.BorderSizePixel  = 0
            T.ZIndex           = 200
            T.Parent           = SG
            rnd(T, 13)
            brd(T, item.col, 1.5)

            local Bar = Instance.new("Frame")
            Bar.Size             = UDim2.fromOffset(3, 56)
            Bar.BackgroundColor3 = item.col
            Bar.BorderSizePixel  = 0
            Bar.ZIndex           = 201
            Bar.Parent           = T
            rnd(Bar, 2)

            local Ic = lbl(T, item.icon, 22, item.col, Enum.Font.GothamBold, Enum.TextXAlignment.Center)
            Ic.Size     = UDim2.fromOffset(44, 56)
            Ic.Position = UDim2.fromOffset(6, 0)
            Ic.ZIndex   = 202

            local TT = lbl(T, item.title, 13, C.text, Enum.Font.GothamBold, Enum.TextXAlignment.Left, Enum.TextYAlignment.Top)
            TT.Size     = UDim2.fromOffset(200, 20)
            TT.Position = UDim2.fromOffset(54, 10)
            TT.ZIndex   = 202

            local TM = lbl(T, item.msg, 10, item.col, Enum.Font.Gotham, Enum.TextXAlignment.Left, Enum.TextYAlignment.Top)
            TM.Size     = UDim2.fromOffset(200, 16)
            TM.Position = UDim2.fromOffset(54, 30)
            TM.ZIndex   = 202

            tw(T, .35, {Position = UDim2.new(1, -286, 0, 16)}, Enum.EasingStyle.Back)
            task.wait(2.8)
            tw(T, .28, {Position = UDim2.new(1, 10, 0, 16)})
            task.wait(.32)
            T:Destroy()
            task.wait(.1)
        end
        toastBusy = false
    end)
end

