local function tw(obj, t, props, sty, dir)
    TweenService:Create(obj,
        TweenInfo.new(t, sty or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out),
        props):Play()
end

local function rnd(obj, r)
    local u = Instance.new("UICorner")
    u.CornerRadius = UDim.new(0, r or 12)
    u.Parent = obj
end

local function brd(obj, col, thick, tr)
    local s = Instance.new("UIStroke")
    s.Color        = col   or C.border
    s.Thickness    = thick or 1
    s.Transparency = tr    or 0
    s.Parent = obj
    return s
end

local function lbl(parent, txt, sz, col, fnt, xa, ya)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.Text           = txt
    l.TextSize       = sz  or 13
    l.TextColor3     = col or C.text
    l.Font           = fnt or Enum.Font.GothamBold
    l.TextXAlignment = xa  or Enum.TextXAlignment.Left
    l.TextYAlignment = ya  or Enum.TextYAlignment.Center
    l.Parent         = parent
    return l
end

